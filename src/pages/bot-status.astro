---
import Layout from '../layouts/Layout.astro';
import Section from '../components/ui/Section.astro';

const title = 'Bot Status Monitor';
const description = 'Real-time status monitoring for Discord bot operations';
---

<Layout title={title} description={description}>
  <Section id="bot-status" title="Bot Status Monitor" subtitle="Real-time monitoring and control">
    <div class="max-w-6xl mx-auto space-y-6">

      <!-- Status Overview Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Uptime Card -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Uptime</h3>
            <div id="status-indicator" class="w-3 h-3 rounded-full bg-gray-400"></div>
          </div>
          <p id="uptime" class="text-3xl font-bold text-primary dark:text-sky-400">--</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            Started: <span id="start-time">--</span>
          </p>
        </div>

        <!-- Pool Status Card -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Pool Status</h3>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Cards:</span>
              <span id="pool-cards" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Main Emails:</span>
              <span id="pool-emails-main" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Fusion Emails:</span>
              <span id="pool-emails-fusion" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Wool Emails:</span>
              <span id="pool-emails-wool" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
          </div>
        </div>

        <!-- System Metrics Card -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">System Metrics</h3>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">CPU:</span>
              <span id="cpu-usage" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Memory:</span>
              <span id="memory-usage" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Threads:</span>
              <span id="threads" class="font-semibold text-gray-900 dark:text-white">--</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Last Command Card -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Last Command Executed</h3>
        <div id="last-command-content" class="space-y-2">
          <p class="text-gray-600 dark:text-gray-400">No commands executed yet</p>
        </div>
      </div>

      <!-- Recent Logs -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 border border-gray-200 dark:border-gray-700">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Logs</h3>
          <button
            id="refresh-logs"
            class="px-4 py-2 bg-primary dark:bg-sky-600 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-sky-700 transition-colors"
          >
            Refresh
          </button>
        </div>
        <div id="logs-container" class="space-y-2 max-h-96 overflow-y-auto">
          <p class="text-gray-600 dark:text-gray-400">Loading logs...</p>
        </div>
      </div>

    </div>
  </Section>
</Layout>

<script>
  // The bot status API is locked to a single trusted origin. Do NOT accept a
  // user-supplied API URL here: earlier revisions let visitors paste arbitrary
  // URLs and stored an operator API key in localStorage, which could be
  // exfiltrated to a malicious host.
  const API_URL = 'https://zreatsbot-production.up.railway.app';

  let eventSource: EventSource | null = null;

  // Uptime tracking
  let botStartTime: Date | null = null;
  let uptimeSecondsBase: number = 0;
  let lastFetchTime: Date | null = null;
  let uptimeInterval: number | null = null;

  // Format uptime duration from seconds
  function formatUptimeFromSeconds(totalSeconds: number): string {
    const days = Math.floor(totalSeconds / (60 * 60 * 24));
    const hours = Math.floor((totalSeconds % (60 * 60 * 24)) / (60 * 60));
    const minutes = Math.floor((totalSeconds % (60 * 60)) / 60);
    const seconds = Math.floor(totalSeconds % 60);

    if (days > 0) return `${days}d ${hours}h ${minutes}m ${seconds}s`;
    if (hours > 0) return `${hours}h ${minutes}m ${seconds}s`;
    if (minutes > 0) return `${minutes}m ${seconds}s`;
    return `${seconds}s`;
  }

  function getCurrentUptimeSeconds(): number {
    if (!lastFetchTime) return uptimeSecondsBase;
    const elapsed = (Date.now() - lastFetchTime.getTime()) / 1000;
    return uptimeSecondsBase + elapsed;
  }

  function updateUptimeDisplay() {
    const el = document.getElementById('uptime');
    if (el) el.textContent = formatUptimeFromSeconds(getCurrentUptimeSeconds());
  }

  function startUptimeTicker() {
    if (uptimeInterval) {
      clearInterval(uptimeInterval);
      uptimeInterval = null;
    }
    updateUptimeDisplay();
    uptimeInterval = window.setInterval(updateUptimeDisplay, 1000);
  }

  // Privacy masking — always masks, because this page is public.
  function maskEmail(email: string): string {
    if (typeof email !== 'string') return '';
    const [localPart, domain] = email.split('@');
    if (!domain) return '*****';
    const halfLength = Math.ceil(localPart.length / 2);
    return `${localPart.substring(0, halfLength)}*****@${domain}`;
  }

  function maskText(text: string): string {
    if (typeof text !== 'string') return '';
    const halfLength = Math.ceil(text.length / 2);
    return text.substring(0, halfLength) + '*****';
  }

  function parseTimestamp(timestamp: string): Date {
    if (typeof timestamp !== 'string') return new Date(NaN);
    if (!timestamp.endsWith('Z') && !timestamp.includes('+')) {
      return new Date(timestamp + 'Z');
    }
    return new Date(timestamp);
  }

  function asString(value: unknown, fallback = ''): string {
    return typeof value === 'string' ? value : fallback;
  }

  function asNumber(value: unknown): string {
    return typeof value === 'number' && Number.isFinite(value) ? String(value) : '--';
  }

  function setText(id: string, value: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  }

  function clearChildren(el: HTMLElement) {
    while (el.firstChild) el.removeChild(el.firstChild);
  }

  // ---------- Data fetchers ----------

  async function fetchStatus() {
    try {
      const response = await fetch(`${API_URL}/status`);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();

      if (data && data.uptime && typeof data.uptime.seconds === 'number' && Number.isFinite(data.uptime.seconds)) {
        uptimeSecondsBase = data.uptime.seconds;
        lastFetchTime = new Date();
        botStartTime = new Date(lastFetchTime.getTime() - uptimeSecondsBase * 1000);
        setText('start-time', botStartTime.toLocaleString());
        startUptimeTicker();
      }

      if (data && data.system) {
        setText('cpu-usage', `${asNumber(data.system.cpu_percent)}%`);
        setText('memory-usage', `${asNumber(data.system.memory_mb)} MB`);
        setText('threads', asNumber(data.system.threads));
      }

      const indicator = document.getElementById('status-indicator');
      if (indicator) {
        indicator.classList.remove('bg-gray-400', 'bg-green-500', 'bg-red-500');
        indicator.classList.add('bg-green-500');
      }

      if (data && data.last_command) {
        updateLastCommand(data.last_command);
      }
    } catch (error) {
      console.error('[Bot Status] Error fetching status');
      document.getElementById('status-indicator')?.classList.add('bg-red-500');
    }
  }

  async function fetchPools() {
    try {
      const response = await fetch(`${API_URL}/pools`);
      const data = await response.json();
      if (data && data.success && data.pools) {
        setText('pool-cards', asNumber(data.pools.cards));
        if (data.pools.emails) {
          setText('pool-emails-main', asNumber(data.pools.emails.main));
          setText('pool-emails-fusion', asNumber(data.pools.emails.fusion));
          setText('pool-emails-wool', asNumber(data.pools.emails.wool));
        }
      }
    } catch {
      console.error('[Bot Status] Error fetching pools');
    }
  }

  async function fetchLogs() {
    const container = document.getElementById('logs-container');
    if (!container) return;

    try {
      const response = await fetch(`${API_URL}/logs?limit=20`);
      const data = await response.json();

      clearChildren(container);

      if (data && data.success && Array.isArray(data.logs) && data.logs.length > 0) {
        for (const log of data.logs) {
          container.appendChild(renderLogEntry(log));
        }
      } else {
        const p = document.createElement('p');
        p.className = 'text-gray-600 dark:text-gray-400';
        p.textContent = 'No logs available';
        container.appendChild(p);
      }
    } catch {
      console.error('[Bot Status] Error fetching logs');
    }
  }

  function renderLogEntry(log: unknown): HTMLElement {
    // Untrusted input: every field is placed via textContent, never innerHTML,
    // so any HTML/script in API responses is rendered harmlessly as text.
    const wrapper = document.createElement('div');
    wrapper.className =
      'bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 border border-gray-200 dark:border-gray-600';

    const header = document.createElement('div');
    header.className = 'flex justify-between items-start';

    const title = document.createElement('span');
    title.className = 'font-medium text-gray-900 dark:text-white';
    title.textContent = asString((log as any)?.command_type, 'unknown');

    const tsSpan = document.createElement('span');
    tsSpan.className = 'text-xs text-gray-500 dark:text-gray-400';
    const ts = parseTimestamp(asString((log as any)?.timestamp));
    tsSpan.textContent = Number.isNaN(ts.getTime()) ? '--' : ts.toLocaleString();

    header.appendChild(title);
    header.appendChild(tsSpan);
    wrapper.appendChild(header);

    const emailUsed = (log as any)?.email_used;
    if (typeof emailUsed === 'string' && emailUsed.length > 0) {
      const detail = document.createElement('p');
      detail.className = 'text-sm text-gray-600 dark:text-gray-400 mt-1';
      const pool = asString((log as any)?.email_pool, '');
      detail.textContent = pool
        ? `Email: ${maskEmail(emailUsed)} (${pool})`
        : `Email: ${maskEmail(emailUsed)}`;
      wrapper.appendChild(detail);
    }

    return wrapper;
  }

  function updateLastCommand(command: unknown) {
    const container = document.getElementById('last-command-content');
    if (!container) return;
    clearChildren(container);

    const grid = document.createElement('div');
    grid.className = 'grid grid-cols-2 md:grid-cols-4 gap-4';

    const fields: Array<{ label: string; value: string }> = [
      { label: 'Command', value: asString((command as any)?.type, '--') },
      { label: 'User', value: maskText(asString((command as any)?.user, '')) || '--' },
      { label: 'Channel', value: maskText(asString((command as any)?.channel, '')) || '--' },
      { label: 'Time', value: (() => {
          const ts = parseTimestamp(asString((command as any)?.timestamp));
          return Number.isNaN(ts.getTime()) ? '--' : ts.toLocaleString();
        })() }
    ];

    for (const { label, value } of fields) {
      const cell = document.createElement('div');

      const labelEl = document.createElement('p');
      labelEl.className = 'text-xs text-gray-500 dark:text-gray-400';
      labelEl.textContent = label;

      const valueEl = document.createElement('p');
      valueEl.className = 'font-semibold text-gray-900 dark:text-white';
      valueEl.textContent = value;

      cell.appendChild(labelEl);
      cell.appendChild(valueEl);
      grid.appendChild(cell);
    }

    container.appendChild(grid);
  }

  function fetchAllData() {
    fetchStatus();
    fetchPools();
    fetchLogs();
  }

  function connectSSE() {
    eventSource = new EventSource(`${API_URL}/stream`);

    eventSource.onmessage = (event) => {
      let data: any;
      try {
        data = JSON.parse(event.data);
      } catch {
        return;
      }
      if (!data || typeof data.type !== 'string') return;

      if (data.type === 'heartbeat' && typeof data.uptime === 'string') {
        setText('uptime', data.uptime);
      }
    };

    eventSource.onerror = () => {
      document.getElementById('status-indicator')?.classList.remove('bg-green-500');
      document.getElementById('status-indicator')?.classList.add('bg-red-500');
    };
  }

  document.getElementById('refresh-logs')?.addEventListener('click', fetchLogs);

  connectSSE();
  fetchAllData();
  setInterval(fetchAllData, 10000);
</script>

<style>
  /* Custom scrollbar for logs */
  #logs-container::-webkit-scrollbar {
    width: 8px;
  }

  #logs-container::-webkit-scrollbar-track {
    @apply bg-gray-100 dark:bg-gray-700 rounded;
  }

  #logs-container::-webkit-scrollbar-thumb {
    @apply bg-gray-300 dark:bg-gray-600 rounded;
  }

  #logs-container::-webkit-scrollbar-thumb:hover {
    @apply bg-gray-400 dark:bg-gray-500;
  }
</style>
