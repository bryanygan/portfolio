---
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';

// Get the company logos
interface Experience {
  company: string;
  logo: string;
  position: string;
  period: string;
  description: string | string[];
}

const experiences: Experience[] = [
  {
    company: 'Philadelphia College of Osteopathic Medicine',
    logo: '/assets/svgs/pcom.jpg',
    position: 'Information Technology Services Co-op',
    period: 'Mar 2026 - Present',
    description: 'Resolved end-user help requests by providing hands-on technical support, managing hardware and software issues, and tracking service tickets in TeamDynamix to maintain SLA expectations.',
  },
  {
    company: 'Drexel University',
    logo: '/assets/svgs/drexel.png',
    position: 'IMS Classroom AV & Graphics Lab Assistant',
    period: 'March 2025 - September 2025',
    description: 'Supported classroom technology and graphics services by troubleshooting AV issues, assisting users, handling equipment checkouts, and managing print jobs in a university media environment.',
  },
  {
    company: 'Advantage Solutions',
    logo: '/assets/svgs/advantagesolutions.jpg',
    position: 'Amazon Fresh Brand Ambassador',
    period: 'July 2024 - September 2024',
    description: 'Promoted Amazon Fresh products by preparing samples, engaging customers, maintaining food safety standards, and supporting in-store marketing efforts through active product demonstrations and feedback collection.'
  },

];
---

<Section id="experience" title="Professional Experience">
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      experiences.map(({ company, logo, position, period, description }) => (
        <Card hover={true} class="h-full">
          <div class="p-6 flex flex-col h-full">
            <div class="flex items-center mb-4 min-h-[80px]">
              <div class="w-12 h-12 bg-gray-100 dark:bg-gray-800 rounded-lg overflow-hidden flex items-center justify-center mr-4 flex-shrink-0">
                <img src={logo} alt={company} class="w-10 h-10 object-contain" loading="lazy" />
              </div>
              <div>
                <h3 class="font-bold text-xl">{company}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">{period}</p>
              </div>
            </div>

            <h4 class="text-lg font-bold mb-2 text-primary min-h-[3.5rem]">{position}</h4>
            {Array.isArray(description) ? (
              <ul class="text-gray-600 dark:text-gray-300 text-sm mt-auto list-disc list-inside space-y-1">
                {description.map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 dark:text-gray-300 text-sm mt-auto">{description}</p>
            )}
          </div>
        </Card>
      ))
    }
  </div>
</Section> 