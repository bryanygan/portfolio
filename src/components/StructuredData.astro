---
// This component handles all the structured data (Schema.org) for SEO

interface Props {
  type?: 'person' | 'website';
  title?: string;
  description?: string;
  imageUrl?: string;
}

const {
  type = 'person',
  title = 'Bryan Gan - Software Engineer',
  description = 'Professional portfolio of Bryan Gan, Software Engineer.',
  imageUrl = 'https://bryangan.com/android-chrome-512x512.png'
} = Astro.props;

const baseUrl = 'https://bryangan.com';

// Person Schema
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Bryan Gan",
  "url": baseUrl,
  "image": imageUrl,
  "sameAs": [
    "https://www.linkedin.com/in/bryanygan/",
    "https://github.com/bryanygan"
  ],
  "jobTitle": "Software Engineer",
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "Drexel University"
  },
  "description": description
};

// Website Schema — the site name is fixed regardless of which page the
// schema is rendered on, so crawlers don't see conflicting WebSite entities.
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": baseUrl,
  "name": "Bryan Gan — Portfolio",
  "description": description,
  "author": {
    "@type": "Person",
    "name": "Bryan Gan"
  }
};

// Choose which schema to use based on the type prop
const schema = type === 'person' ? personSchema : websiteSchema;
---

<script type="application/ld+json" set:html={JSON.stringify(schema)}></script> 